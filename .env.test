# .env.test
#
# Environment variables สำหรับ test suite ทั้งหมด
# KHÔNG commit ไฟล์นี้ถ้ามี secrets จริง — ใช้ .env.test.example แทน
# เหตุผล: แยก test config ออกจาก development config เพื่อความปลอดภัย

# ─── Database ────────────────────────────────────────────────────────────────────

# Test database แยกจาก development database
# ต้องสร้าง database นี้ก่อน: createdb studio_test
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/studio_test

# ─── Backend API ─────────────────────────────────────────────────────────────────

# URL ของ FastAPI BE server สำหรับ integration tests
# BE_BASE_URL ใช้เมื่อ integration test ต้องการ real HTTP (ไม่ใช่ in-process)
BE_BASE_URL=http://localhost:8000

# ─── Frontend ────────────────────────────────────────────────────────────────────

# URL ของ Vite FE dev server สำหรับ Playwright tests
FE_BASE_URL=http://localhost:5173

# ─── Playwright Locator Mode ─────────────────────────────────────────────────────

# STRICT_LOCATOR=true  → ต้องมี data-testid เสมอ ห้าม fallback ไปใช้ XPath
# STRICT_LOCATOR=false → fallback ไปใช้ XPath ได้ (ใช้ตอน FE ยังพัฒนาอยู่)
# ตั้งเป็น true เมื่อ FE พัฒนาครบแล้วและ data-testid ครบทุก element
STRICT_LOCATOR=false

# ─── Test Credentials ────────────────────────────────────────────────────────────

# Credentials เหล่านี้ต้องตรงกับ seed data ใน conftest.py
# ห้ามใช้ credentials จริงของ production
TEST_DEVELOPER_EMAIL=developer@test.com
TEST_OWNER_EMAIL=owner@test.com
TEST_BRANCH_MASTER_EMAIL=bm_pattaya@test.com
TEST_ADMIN_EMAIL=admin@test.com
TEST_TRAINER_EMAIL=trainer@test.com
TEST_PASSWORD=test_pass
TEST_PIN=123456

# ─── Auth Settings ────────────────────────────────────────────────────────────────

# JWT secret สำหรับ test (ต่างจาก production secret)
JWT_SECRET_KEY=test_jwt_secret_do_not_use_in_production
JWT_ALGORITHM=HS256

# PIN session expiry (วินาที) — ตั้งสั้นลงใน test เพื่อทดสอบ expiry
PIN_SESSION_EXPIRY_SECONDS=18000

# Developer API key สำหรับ internal endpoints
DEVELOPER_API_KEY=test_dev_api_key_12345

# ─── External Services (Mock) ─────────────────────────────────────────────────────

# ใน test env ไม่ส่ง email จริง — ใช้ mock/print แทน
EMAIL_BACKEND=mock

# ใน test env ไม่ส่ง LINE notify จริง
LINE_NOTIFY_ENABLED=false

# ใน test env ไม่ต่อ Google Drive จริง
GOOGLE_DRIVE_ENABLED=false

# Fixed OTP สำหรับ test (แทนที่ OTP random จริง)
TEST_FIXED_OTP=654321

# ─── Allure ──────────────────────────────────────────────────────────────────────

# Folder สำหรับ Allure results
ALLURE_RESULTS_DIR=allure-results
